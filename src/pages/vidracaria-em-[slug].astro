---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../data/config';
import { BAIRROS, getSlug, getBairroFormatado } from '../data/bairros';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return BAIRROS.map((bairro) => ({
    params: { slug: getSlug(bairro) },
    props: { bairro },
  }));
}

const { bairro } = Astro.props;
const bairroFormatado = getBairroFormatado(bairro);
const services = (await getCollection('servicos')).slice(0, 6);

// Lógica de variação de conteúdo para evitar duplicidade (SEO)
const variations = [
  {
    heroTitle: `Vidraçaria ${bairroFormatado}: Qualidade e Rapidez`,
    heroDesc: `Procurando vidros de alta performance ${bairroFormatado}? Somos especialistas em instalações seguras e acabamento de luxo para sua residência ou empresa.`,
    aboutTitle: `Sua Vidraçaria de Confiança ${bairroFormatado}`,
    aboutText: `Atendemos toda a região de ${bairro} com uma equipe técnica altamente qualificada. Se você busca uma vidraçaria ${bairroFormatado} que entenda de precisão e segurança, a Mais Vidros Salvador é sua melhor escolha.`,
    ctaTitle: `Transforme seu projeto ${bairroFormatado} hoje!`,
    ctaDesc: `Ligue para o nosso telefone de vidraçaria ou mande uma mensagem no whatsapp agora mesmo para um orçamento ${bairroFormatado}.`
  },
  {
    heroTitle: `Vidraçaria ${bairroFormatado} | Instalação e Manutenção`,
    heroDesc: `A melhor vidraçaria ${bairroFormatado} para o seu projeto. Trabalhamos com vidros temperados, espelhos e esquadrias com o melhor custo-benefício da região.`,
    aboutTitle: `Referência em Vidraçaria ${bairroFormatado}`,
    aboutText: `Com anos de experiência atendendo a região de ${bairro}, nossa missão é entregar sofisticação e durabilidade. Cada projeto ${bairroFormatado} é executado com materiais certificados e agilidade total.`,
    ctaTitle: `Orçamento gratuito ${bairroFormatado}`,
    ctaDesc: `Buscando vidraçaria perto de mim aberto agora ${bairroFormatado}? Nossa equipe está pronta para te atender com agilidade e transparência.`
  },
  {
    heroTitle: `Vidraçaria ${bairroFormatado} de Alta Performance`,
    heroDesc: `Segurança e beleza para sua obra ${bairroFormatado}. Especialistas em box, cortinas de vidro e projetos sob medida com garantia total de qualidade.`,
    aboutTitle: `Atendimento Exclusivo ${bairroFormatado}`,
    aboutText: `Nossa vidraçaria ${bairroFormatado} se destaca pelo acabamento premium e atendimento personalizado. Levamos até você ${bairroFormatado} as tendências mais modernas do mercado de vidros.`,
    ctaTitle: `Fale com a Mais Vidros ${bairroFormatado}`,
    ctaDesc: `Não feche seu projeto ${bairroFormatado} sem antes consultar nossos especialistas. Qualidade garantida com o melhor preço da capital.`
  },
  {
    heroTitle: `Vidraçaria ${bairroFormatado} e Soluções em Vidro`,
    heroDesc: `Atendemos o bairro de ${bairro} com soluções completas em vidraçaria. Desde reparos urgentes até grandes projetos arquitetônicos com vidros temperados.`,
    aboutTitle: `O melhor acabamento de ${bairro}`,
    aboutText: `Se você mora ${bairroFormatado} e precisa de um serviço de vidraçaria rápido e limpo, conte conosco. Somos especialistas em transformar ambientes ${bairroFormatado} com a clareza do vidro.`,
    ctaTitle: `Atendimento imediato ${bairroFormatado}`,
    ctaDesc: `Precisa de um telefone de vidraçaria ${bairroFormatado}? Clique no botão abaixo e fale direto com um consultor técnico pelo WhatsApp.`
  }
];

// Seleciona uma variação baseada no comprimento do nome do bairro para garantir distribuição
const vIndex = bairro.length % variations.length;
const content = variations[vIndex];
---

<Layout title={`Vidraçaria ${bairroFormatado} | Mais Vidros Salvador`}>
	<main>
		<!-- HERO SECTION -->
		<section class="min-h-[70vh] flex items-center bg-gradient-to-br from-white to-gray-50 border-b border-gray-100 overflow-hidden">
			<div class="container mx-auto">
				<div class="max-w-4xl">
					<span class="inline-block px-4 py-2 bg-primary text-secondary font-black text-xs md:text-sm uppercase tracking-[0.2em] rounded-lg mb-8 shadow-md">
						Atendimento {bairroFormatado}
					</span>
					<h1 class="text-5xl md:text-7xl font-black text-gray-900 leading-[1.1] mb-8 tracking-tighter">
						{content.heroTitle}
					</h1>
					<p class="text-lg md:text-xl text-gray-600 max-w-2xl leading-relaxed mb-12 font-medium">
						{content.heroDesc}
					</p>
					
					<div class="flex flex-wrap gap-6">
						<a href={`https://wa.me/${SITE_CONFIG.nap.whatsapp}`} target="_blank" class="bg-secondary text-white px-10 py-6 rounded-2xl font-black text-xl hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-secondary/20 flex items-center gap-4">
							Orçamento no WhatsApp <span>📱</span>
						</a>
						<a href="/servicos" class="bg-white/80 backdrop-blur-md border-4 border-white text-gray-900 px-10 py-6 rounded-2xl font-black text-xl hover:border-primary hover:scale-105 active:scale-95 transition-all shadow-xl">
							Nossos Serviços
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- SOBRE RESUMO LOCALIZADO -->
		<section class="bg-gray-900 text-white relative overflow-hidden">
			<div class="absolute right-0 top-0 w-1/3 h-full bg-primary/10 blur-[120px] rounded-full"></div>
			<div class="container mx-auto relative z-10">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
					<div>
						<h2 class="text-4xl md:text-6xl font-black mb-8 leading-tight tracking-tighter text-primary italic">{content.aboutTitle}</h2>
						<p class="text-xl text-gray-100 leading-relaxed mb-10 font-medium">
							{content.aboutText}
						</p>
						<a href={`https://wa.me/${SITE_CONFIG.nap.whatsapp}`} class="inline-block bg-primary text-secondary px-10 py-5 rounded-2xl font-black text-xl hover:bg-white hover:scale-105 active:scale-95 transition-all shadow-xl shadow-primary/20">
							Falar com Especialista
						</a>
					</div>
					<div class="bg-white/5 p-12 rounded-[4rem] border border-white/10 backdrop-blur-sm text-center">
						<div class="text-9xl mb-6">📍</div>
						<p class="text-2xl font-black text-primary">Salvador - {bairro}</p>
					</div>
				</div>
			</div>
		</section>

		<!-- SERVIÇOS GRID -->
		<section id="servicos">
			<div class="container mx-auto">
				<div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
					<div class="max-w-2xl">
						<h2 class="text-4xl md:text-6xl font-black text-gray-900 mb-6 tracking-tighter underline decoration-primary decoration-8">Vidraçaria {bairroFormatado}</h2>
						<p class="text-xl text-gray-600 leading-relaxed font-bold uppercase tracking-widest text-sm opacity-60">Serviços Disponíveis para sua Região</p>
					</div>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
					{services.map(s => (
						<a href={`/servicos/${s.slug}-em-${getSlug(bairro)}`} class="group bg-white p-12 rounded-[3rem] border border-gray-100 shadow-sm hover:shadow-2xl transition-all h-full flex flex-col justify-between hover:border-primary">
							<div>
								<div class="text-7xl mb-10 group-hover:scale-110 transition-transform duration-500">{s.data.icon}</div>
								<h3 class="text-3xl font-black text-gray-900 mb-6 tracking-tighter group-hover:text-secondary transition-colors">{s.data.title.replace('em Salvador', bairroFormatado)}</h3>
								<p class="text-gray-600 mb-10 leading-relaxed text-lg font-medium">{s.data.description.replace('em Salvador', bairroFormatado)}</p>
							</div>
							<span class="text-secondary font-black flex items-center gap-2 group-hover:gap-6 transition-all uppercase tracking-[0.2em] text-sm italic">
								Solicitar {bairroFormatado} <span>&rarr;</span>
							</span>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- CTA FINAL LOCALIZADO -->
		<section class="bg-primary">
			<div class="container mx-auto text-center">
				<h2 class="text-4xl md:text-6xl font-black text-secondary leading-tight mb-12 tracking-tighter">
					{content.ctaTitle}
				</h2>
				<p class="text-xl md:text-2xl text-secondary opacity-90 max-w-3xl mx-auto mb-16 font-bold leading-relaxed uppercase tracking-widest">
					{content.ctaDesc}
				</p>
				<div class="flex justify-center">
					<a href={`https://wa.me/${SITE_CONFIG.nap.whatsapp}`} target="_blank" class="bg-secondary text-white px-10 py-7 md:px-12 md:py-8 rounded-[2.5rem] font-black text-2xl hover:scale-110 active:scale-95 transition-all shadow-2xl flex items-center justify-center text-center gap-4 max-w-full">
						Solicitar Orçamento agora <span>📱</span>
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
