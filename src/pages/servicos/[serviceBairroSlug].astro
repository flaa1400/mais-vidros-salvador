---
import Layout from '../../layouts/Layout.astro';
import { SITE_CONFIG } from '../../data/config';
import { BAIRROS, getSlug, getBairroFormatado, getBairroFormatadoDe, getBairroPageSlug, getServiceBairroSlug } from '../../data/bairros';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('servicos');
  const paths = [];

  BAIRROS.forEach((bairro) => {
    services.forEach((service) => {
      paths.push({
        params: { 
          serviceBairroSlug: getServiceBairroSlug(service.slug, bairro)
        },
        props: { 
          bairro, 
          service
        },
      });
    });
  });

  return paths;
}

const { bairro, service } = Astro.props;
const bairroFormatado = getBairroFormatado(bairro);
const bairroFormatadoDe = getBairroFormatadoDe(bairro);

// Dynamically substitute "Salvador" with the neighborhood name grammatically
const serviceTitle = service.data.title.replace('em Salvador', bairroFormatado);
const serviceDesc = service.data.description.replace('em Salvador', bairroFormatado);

// Lógica de variação para as combinações
const variations = [
  {
    intro: `Especialistas em ${serviceTitle}, atendendo com agilidade e precisão técnica toda a região.`,
    detail: `Nossa equipe técnica conhece bem as necessidades dos clientes ${bairroFormatado}, oferecendo soluções de vidraçaria que aliam segurança e design moderno.`,
    safety: `Ao escolher o nosso serviço de ${serviceTitle}, você garante materiais certificados pelas normas da ABNT e um acabamento impecável.`,
    closing: `Não feche seu projeto ${bairroFormatado} sem falar conosco. Temos o melhor custo-benefício para sua obra ou reforma.`
  },
  {
    intro: `Buscando ${serviceTitle}? Entregamos qualidade premium e instalação rápida para sua total tranquilidade.`,
    detail: `A Mais Vidros Salvador é referência ${bairroFormatado}, transformando ambientes com a sofisticação e a durabilidade que só o vidro de alta performance oferece.`,
    safety: `Segurança é nossa prioridade em cada instalação de ${serviceTitle}, utilizando ferragens de alto padrão resistentes à maresia.`,
    closing: `Fale agora com um consultor e peça seu orçamento para ${serviceTitle} via WhatsApp.`
  },
  {
    intro: `A melhor opção para ${serviceTitle} com atendimento exclusivo e suporte técnico especializado.`,
    detail: `Valorize seu imóvel ${bairroFormatado} com projetos sob medida que se adaptam perfeitamente ao seu espaço e estilo de vida.`,
    safety: `Garantimos a estanqueidade e a firmeza estrutural em todo serviço de ${serviceTitle} realizado pela nossa vidraçaria.`,
    closing: `Agende uma visita técnica ${bairroFormatado} e descubra por que somos líderes em vidros de alta qualidade na capital.`
  }
];

// Seleciona variação baseada na combinação única de serviço e bairro
const vIndex = (service.slug.length + bairro.length) % variations.length;
const content = variations[vIndex];
---

<Layout title={`${serviceTitle} | Mais Vidros Salvador`}>
	<main>
		<!-- HERO LOCALIZADO DO SERVIÇO -->
		<section class="min-h-[60vh] flex items-center bg-gray-900 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-primary/5 blur-[100px]"></div>
			<div class="container mx-auto relative z-10">
				<div class="max-w-4xl">
					<nav class="flex gap-4 mb-8 text-sm font-bold uppercase tracking-widest opacity-60">
            <a href="/" class="hover:text-primary">Início</a>
            <span>/</span>
            <a href={`/${getBairroPageSlug(bairro)}`} class="hover:text-primary">{bairro}</a>
          </nav>
					<h1 class="text-5xl md:text-7xl font-black leading-[1.1] mb-8 tracking-tighter">
						{serviceTitle.split(' no ')[0].split(' na ')[0].split(' nos ')[0].split(' em ')[0]} <span class="text-primary italic">{bairroFormatado}</span>
					</h1>
					<p class="text-xl md:text-2xl text-gray-300 max-w-2xl leading-relaxed mb-12 font-medium">
						{content.intro}
					</p>
					
					<div class="flex flex-wrap gap-6">
						<a href={`https://wa.me/${SITE_CONFIG.nap.whatsapp}`} target="_blank" class="bg-primary text-secondary px-10 py-6 rounded-2xl font-black text-xl hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-primary/20 flex items-center gap-4">
							Orçamento {bairroFormatado} <span>📱</span>
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- CONTEÚDO TÉCNICO LOCALIZADO -->
		<section>
			<div class="container mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
					<div class="prose prose-xl max-w-none">
            <p class="text-2xl text-gray-600 leading-relaxed mb-12 font-medium">
              {content.detail}
            </p>
            <p class="text-xl text-gray-600 leading-relaxed mb-12">
              {content.safety}
            </p>
            <div class="p-10 bg-gray-50 rounded-[3rem] border border-gray-100 mb-12">
              <h3 class="text-3xl font-black text-gray-900 mb-6 tracking-tighter">Vantagens:</h3>
              <ul class="space-y-4">
                <li class="flex items-center gap-4 font-bold text-gray-700">✅ Atendimento prioritário em toda a região {bairroFormatadoDe}.</li>
                <li class="flex items-center gap-4 font-bold text-gray-700">✅ Medição técnica gratuita no seu endereço.</li>
                <li class="flex items-center gap-4 font-bold text-gray-700">✅ Instalação limpa e rápida por equipe própria.</li>
                <li class="flex items-center gap-4 font-bold text-gray-700">✅ Materiais certificados com garantia total.</li>
              </ul>
            </div>
            <p class="text-xl text-gray-600 leading-relaxed">
              {content.closing}
            </p>
          </div>

          <div class="sticky top-32 space-y-8">
            <div class="bg-secondary p-12 rounded-[3rem] text-white shadow-2xl">
              <div class="text-6xl mb-8">{service.data.icon}</div>
              <h4 class="text-3xl font-black mb-6 tracking-tighter">Sobre {serviceTitle}</h4>
              <p class="text-lg opacity-80 leading-relaxed font-medium mb-10">
                {serviceDesc}
              </p>
              <a href={`https://wa.me/${SITE_CONFIG.nap.whatsapp}`} class="block w-full bg-primary text-secondary text-center py-6 rounded-2xl font-black text-xl hover:bg-white transition-all">
                Chamar no WhatsApp
              </a>
            </div>
          </div>
				</div>
			</div>
		</section>

		<!-- CTA FINAL -->
		<section class="bg-primary">
			<div class="container mx-auto text-center">
				<h2 class="text-4xl md:text-6xl font-black text-secondary leading-tight mb-12 tracking-tighter">
					Pronto para seu projeto {bairroFormatado}?
				</h2>
				<p class="text-xl md:text-2xl text-secondary opacity-90 max-w-3xl mx-auto mb-16 font-bold leading-relaxed uppercase tracking-widest">
					Ligue para o nosso telefone de vidraçaria ou mande uma mensagem agora mesmo.
				</p>
				<div class="flex justify-center">
					<a href={`https://wa.me/${SITE_CONFIG.nap.whatsapp}`} target="_blank" class="bg-secondary text-white px-10 py-7 md:px-12 md:py-8 rounded-[2.5rem] font-black text-2xl hover:scale-110 active:scale-95 transition-all shadow-2xl flex items-center justify-center text-center gap-4 max-w-full">
						Solicitar Orçamento <span>📱</span>
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
