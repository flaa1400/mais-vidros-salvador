---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
	.filter(p => p.slug !== entry.slug)
	.slice(0, 3);
---

<Layout title={`${entry.data.title} | Blog Vidraçaria Salvador`}>
	<main>
		<!-- BLOG HEADER -->
		<section class="bg-white pt-48 pb-20 border-b border-gray-100">
			<div class="container mx-auto">
				<div class="max-w-4xl">
					<div class="flex items-center gap-4 text-secondary font-black uppercase tracking-widest text-sm mb-8">
						<span>Dicas do Mestre</span>
						<span>•</span>
						<time>{entry.data.pubDate.toLocaleDateString('pt-BR')}</time>
					</div>
					<h1 class="text-5xl md:text-8xl font-black text-gray-900 leading-tight mb-8 italic">
						"{entry.data.title}"
					</h1>
					<div class="flex items-center gap-4">
						<div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center text-xl shadow-lg border-2 border-white">🎨</div>
						<span class="font-bold text-gray-500 uppercase tracking-widest text-xs">Postado por <span class="text-gray-900">{entry.data.author}</span></span>
					</div>
				</div>
			</div>
		</section>

		<!-- BLOG CONTENT -->
		<section class="bg-white">
			<div class="container mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-4 gap-20">
					<!-- ARTICLE -->
					<div class="lg:col-span-3">
						<article class="max-w-none prose prose-xl prose-slate prose-headings:text-gray-900 prose-headings:font-black prose-p:text-gray-600 prose-p:leading-relaxed prose-strong:text-secondary prose-blockquote:border-primary prose-blockquote:text-gray-900 prose-blockquote:font-black prose-blockquote:italic">
							<Content />
						</article>
						
						<!-- RELATED POSTS -->
						{relatedPosts.length > 0 && (
							<div class="mt-32 pt-20 border-t border-gray-100">
								<h3 class="text-3xl font-black text-gray-900 mb-12 uppercase tracking-tight italic">Outras Dicas de Obra e Reforma</h3>
								<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
									{relatedPosts.map(p => (
										<a href={`/blog/${p.slug}`} class="group p-8 bg-gray-50 rounded-3xl border border-gray-100 hover:border-primary transition-all">
											<h4 class="text-xl font-black text-gray-900 mb-4 group-hover:text-secondary transition-colors">"{p.data.title}"</h4>
											<p class="text-gray-500 text-sm font-bold uppercase tracking-widest">Ler Dica &rarr;</p>
										</a>
									))}
								</div>
							</div>
						)}
					</div>

					<!-- SIDEBAR -->
					<aside class="space-y-12">
						<div class="sticky top-32 space-y-10">
							<div class="bg-gray-900 rounded-[3rem] p-10 text-white shadow-2xl relative overflow-hidden group">
								<div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
								<h3 class="text-2xl font-black mb-6 relative z-10">Economize na sua Obra!</h3>
								<p class="text-gray-400 mb-8 font-medium relative z-10 leading-relaxed">Nossos vidros temperados duram 3x mais que a concorrência devido ao processo exclusivo de têmpera.</p>
								<a href="/contato" class="block w-full bg-primary text-secondary text-center py-5 rounded-2xl font-black text-lg relative z-10 hover:scale-105 transition-all">
									Pedir Orçamento
								</a>
							</div>
							
							<div class="p-10 border-4 border-dashed border-gray-100 rounded-[3rem]">
								<h4 class="font-black text-gray-900 mb-6 uppercase tracking-widest text-xs">Dúvidas Frequentes</h4>
								<ul class="space-y-6">
									<li><a href="#" class="text-gray-500 hover:text-secondary font-bold transition-colors">Como parcelar o box?</a></li>
									<li><a href="#" class="text-gray-500 hover:text-secondary font-bold transition-colors">Qual prazo de entrega?</a></li>
									<li><a href="#" class="text-gray-500 hover:text-secondary font-bold transition-colors">Atendem Lauro de Freitas?</a></li>
								</ul>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</section>
	</main>
</Layout>
