---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../data/config';
import { getCollection } from 'astro:content';

const services = (await getCollection('servicos')).slice(0, 6);

const pageTitle = "Vidraçaria perto de mim aberto agora em Salvador";
const pageDesc = "Procurando por uma vidraçaria perto de mim aberta agora em Salvador? Atendimento imediato, instalação rápida de vidro temperado e espelhos em toda a capital.";
---

<Layout title={`${pageTitle} | Mais Vidros Salvador`}>
	<main>
		<!-- HERO SECTION -->
		<section class="min-h-[80vh] flex items-center bg-gradient-to-br from-white to-gray-50 border-b border-gray-100 overflow-hidden">
			<div class="container mx-auto">
				<div class="max-w-4xl">
					<span class="inline-block px-4 py-2 bg-primary text-secondary font-black text-xs md:text-sm uppercase tracking-[0.2em] rounded-lg mb-8 shadow-md animate-bounce">
						Atendimento Imediato ⚡
					</span>
					<h1 class="text-5xl md:text-7xl font-black text-gray-900 leading-[1.1] mb-8 tracking-tighter">
						Vidraçaria perto de mim <span class="text-secondary italic">aberto agora</span> em Salvador.
					</h1>
					<p class="text-lg md:text-xl text-gray-600 max-w-2xl leading-relaxed mb-12 font-medium">
						Sua busca terminou! Somos a vidraçaria em Salvador com a equipe técnica mais ágil da região. Atendemos urgências e projetos sob medida com máxima rapidez e precisão técnica.
					</p>
					
					<div class="flex flex-wrap gap-6">
						<a href={`https://wa.me/${SITE_CONFIG.nap.whatsapp}`} target="_blank" class="bg-secondary text-white px-10 py-6 rounded-2xl font-black text-xl hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-secondary/20 flex items-center gap-4">
							Chamar no WhatsApp <span>📱</span>
						</a>
						<a href="/servicos" class="bg-white/80 backdrop-blur-md border-4 border-white text-gray-900 px-10 py-6 rounded-2xl font-black text-xl hover:border-primary hover:scale-105 active:scale-95 transition-all shadow-xl">
							Ver Serviços
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- POR QUE ESCOLHER AGORA -->
		<section class="bg-gray-900 text-white relative overflow-hidden">
			<div class="absolute right-0 top-0 w-1/3 h-full bg-primary/10 blur-[120px] rounded-full"></div>
			<div class="container mx-auto relative z-10">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
					<div>
						<h2 class="text-4xl md:text-6xl font-black mb-8 leading-tight tracking-tighter text-primary italic">Precisão técnica no seu endereço.</h2>
						<p class="text-xl text-gray-100 leading-relaxed mb-10 font-medium">
							Se você precisa de um vidraceiro em Salvador agora, nossa equipe está de prontidão. Especialistas em vidros temperados, boxes, espelhos e manutenção de esquadrias com materiais certificados.
						</p>
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-12">
							<div class="flex items-center gap-4">
								<span class="text-3xl">📏</span>
								<span class="font-bold">Medição Técnica Grátis</span>
							</div>
							<div class="flex items-center gap-4">
								<span class="text-3xl">🚀</span>
								<span class="font-bold">Instalação Express</span>
							</div>
						</div>
						<a href={`https://wa.me/${SITE_CONFIG.nap.whatsapp}`} class="inline-block bg-primary text-secondary px-10 py-5 rounded-2xl font-black text-xl hover:bg-white hover:scale-105 active:scale-95 transition-all shadow-xl shadow-primary/20">
							Solicitar Visita Agora
						</a>
					</div>
					<div class="bg-white/5 p-12 rounded-[4rem] border border-white/10 backdrop-blur-sm text-center">
						<div class="text-9xl mb-6">🏙️</div>
						<p class="text-2xl font-black text-primary">Atendimento em toda Salvador</p>
						<p class="text-gray-400 mt-4 font-medium uppercase tracking-widest text-sm">24 Horas no WhatsApp</p>
					</div>
				</div>
			</div>
		</section>

		<!-- SERVIÇOS EM DESTAQUE -->
		<section>
			<div class="container mx-auto">
				<div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
					<div class="max-w-2xl">
						<h2 class="text-4xl md:text-6xl font-black text-gray-900 mb-6 tracking-tighter underline decoration-primary decoration-8">Serviços Disponíveis</h2>
						<p class="text-xl text-gray-600 leading-relaxed font-bold uppercase tracking-widest text-sm opacity-60">Qualidade Garantida e Agilidade Total</p>
					</div>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
					{services.map(s => (
						<a href={`/servicos/${s.slug}`} class="group bg-white p-12 rounded-[3rem] border border-gray-100 shadow-sm hover:shadow-2xl transition-all h-full flex flex-col justify-between hover:border-primary">
							<div>
								<div class="text-7xl mb-10 group-hover:scale-110 transition-transform duration-500">{s.data.icon}</div>
								<h3 class="text-3xl font-black text-gray-900 mb-6 tracking-tighter group-hover:text-secondary transition-colors">{s.data.title}</h3>
								<p class="text-gray-600 mb-10 leading-relaxed text-lg font-medium">{s.data.description}</p>
							</div>
							<span class="text-secondary font-black flex items-center gap-2 group-hover:gap-6 transition-all uppercase tracking-[0.2em] text-sm italic">
								Mais Informações <span>&rarr;</span>
							</span>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- CTA FINAL -->
		<section class="bg-primary">
			<div class="container mx-auto text-center">
				<h2 class="text-4xl md:text-6xl font-black text-secondary leading-tight mb-12 tracking-tighter">
					Não perca tempo procurando!
				</h2>
				<p class="text-xl md:text-2xl text-secondary opacity-90 max-w-3xl mx-auto mb-16 font-bold leading-relaxed uppercase tracking-widest">
					A vidraçaria mais próxima de você em Salvador está a um clique de distância.
				</p>
				<div class="flex justify-center">
					<a href={`https://wa.me/${SITE_CONFIG.nap.whatsapp}`} target="_blank" class="bg-secondary text-white px-10 py-7 md:px-12 md:py-8 rounded-[2.5rem] font-black text-2xl hover:scale-110 active:scale-95 transition-all shadow-2xl flex items-center justify-center text-center gap-4 max-w-full">
						Falar com Vidraceiro Agora <span>📱</span>
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
