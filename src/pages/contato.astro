---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('servicos');
---

<Layout title="Contato | Mais Vidros Salvador">
	<main>
		<!-- CONTATO HERO -->
		<section class="bg-secondary pt-48 pb-32 text-center relative overflow-hidden">
			<div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10"></div>
			<div class="container mx-auto relative z-10">
				<h1 class="text-6xl md:text-8xl font-black text-white leading-tight mb-8">Fale <span class="text-primary italic">Conosco</span></h1>
				<p class="text-xl md:text-2xl text-blue-100 max-w-2xl mx-auto font-medium">Orçamentos rápidos por WhatsApp ou formulário. Atendimento em toda Salvador.</p>
			</div>
		</section>

		<!-- CONTATO SECTIONS -->
		<section class="bg-white">
			<div class="container mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
					<!-- NAP & INFO -->
					<div class="space-y-16">
						<div>
							<h2 class="text-4xl font-black text-gray-900 mb-8 uppercase tracking-tighter">Nossa <span class="text-secondary">Sede</span></h2>
							<div class="space-y-10">
								<div class="flex gap-8 group">
									<div class="w-20 h-20 bg-primary/20 rounded-[2rem] flex items-center justify-center text-4xl shrink-0 group-hover:bg-primary transition-all">📍</div>
									<div class="pt-2">
										<h3 class="text-2xl font-black text-gray-900 mb-2 underline decoration-primary decoration-4">Sede Administrativa</h3>
										<p class="text-xl text-gray-600 font-medium leading-relaxed">
											Av. Cardeal Avelar Brandão Villela, 1647 <br/>
											Mata Escura, Salvador - BA
										</p>
									</div>
								</div>
								
								<div class="flex gap-8 group">
									<div class="w-20 h-20 bg-primary/20 rounded-[2rem] flex items-center justify-center text-4xl shrink-0 group-hover:bg-primary transition-all">📞</div>
									<div class="pt-2">
										<h3 class="text-2xl font-black text-gray-900 mb-2 underline decoration-primary decoration-4">Telefone</h3>
										<p class="text-xl text-gray-600 font-bold leading-relaxed tracking-wider">
											(11) 96429-9548 (WhatsApp)
										</p>
									</div>
								</div>

								<div class="flex gap-8 group">
									<div class="w-20 h-20 bg-primary/20 rounded-[2rem] flex items-center justify-center text-4xl shrink-0 group-hover:bg-primary transition-all">⏰</div>
									<div class="pt-2">
										<h3 class="text-2xl font-black text-gray-900 mb-2 underline decoration-primary decoration-4">Horário de Atendimento</h3>
										<p class="text-xl text-gray-600 font-medium leading-relaxed">
											Segunda a Sexta: 08:30 às 18:00
										</p>
									</div>
								</div>
							</div>
						</div>
						
						<!-- MAPA REAL -->
						<div class="bg-gray-100 rounded-[3rem] h-96 overflow-hidden border-4 border-white shadow-2xl">
							<iframe 
								src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3888.1651817036986!2d-38.4503953!3d-12.9228472!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x7161048895080c9%3A0xc00f089e90080f0!2sAv.%20Cardeal%20Avelar%20Brand%C3%A3o%20Villela%2C%201647%20-%20Mata%20Escura%2C%20Salvador%20-%20BA%2C%2041225-000!5e0!3m2!1spt-BR!2sbr!4v1713824500000!5m2!1spt-BR!2sbr" 
								width="100%" 
								height="100%" 
								style="border:0;" 
								allowfullscreen="" 
								loading="lazy" 
								referrerpolicy="no-referrer-when-downgrade"
							></iframe>
						</div>
					</div>

					<!-- FORM -->
					<div class="bg-gray-50 p-12 md:p-20 rounded-[4rem] border border-gray-100 shadow-sm relative">
						<form id="contact-form" class="space-y-10 relative z-10">
							<div>
								<label class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Sobre o que deseja falar?</label>
								<select id="form-servico" class="w-full bg-white border-2 border-gray-100 p-6 rounded-2xl focus:border-primary outline-none transition-all text-xl font-bold appearance-none">
									{services.map(s => (
										<option value={s.data.title.replace(' em Salvador', '')}>{s.data.title.replace(' em Salvador', '')}</option>
									))}
									<option value="Outros Serviços">Outros Serviços</option>
								</select>
							</div>
							<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
								<div>
									<label class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Seu Nome</label>
									<input id="form-nome" type="text" placeholder="Ex: João Silva" class="w-full bg-white border-2 border-gray-100 p-6 rounded-2xl focus:border-primary outline-none transition-all text-xl" />
								</div>
								<div>
									<label class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-4">WhatsApp</label>
									<input id="form-whatsapp" type="tel" placeholder="(71) 99999-9999" class="w-full bg-white border-2 border-gray-100 p-6 rounded-2xl focus:border-primary outline-none transition-all text-xl" />
								</div>
							</div>
							<div>
								<label class="block text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Como podemos te ajudar?</label>
								<textarea id="form-mensagem" rows="4" placeholder="Descreva brevemente sua necessidade..." class="w-full bg-white border-2 border-gray-100 p-6 rounded-2xl focus:border-primary outline-none transition-all text-xl resize-none"></textarea>
							</div>
							<button type="submit" class="w-full bg-secondary text-white p-10 rounded-[2rem] font-black text-2xl hover:bg-black transition-all shadow-2xl flex items-center justify-center gap-6 group">
								Enviar pelo WhatsApp
								<span class="group-hover:translate-x-3 transition-transform">📱</span>
							</button>
						</form>

						<script>
							const form = document.getElementById('contact-form');
							form?.addEventListener('submit', function(e) {
								e.preventDefault();
								const servico  = (document.getElementById('form-servico') as HTMLSelectElement)?.value || '';
								const nome     = (document.getElementById('form-nome') as HTMLInputElement)?.value || '';
								const whatsapp = (document.getElementById('form-whatsapp') as HTMLInputElement)?.value || '';
								const mensagem = (document.getElementById('form-mensagem') as HTMLTextAreaElement)?.value || '';

								const texto =
									`Olá! Vim pelo site da Mais Vidros Salvador e gostaria de um orçamento. 🪟\n\n` +
									`*Serviço:* ${servico}\n` +
									`*Nome:* ${nome || 'Não informado'}\n` +
									`*WhatsApp:* ${whatsapp || 'Não informado'}\n` +
									(mensagem ? `*Mensagem:* ${mensagem}` : '');

								const url = `https://wa.me/5511964299548?text=${encodeURIComponent(texto)}`;
								window.open(url, '_blank');
							});
						</script>
					</div>
				</div>
			</div>
		</section>

		<!-- FINAL WHATSAPP CTA -->
		<section class="bg-primary">
			<div class="container mx-auto text-center">
				<h2 class="text-4xl md:text-6xl font-black text-secondary mb-12">Atendimento Imediato?</h2>
				<a href="https://wa.me/5511964299548" target="_blank" class="bg-secondary text-white px-16 py-8 rounded-[2.5rem] font-black text-3xl hover:scale-105 transition-all shadow-2xl flex items-center gap-6 mx-auto w-fit">
					Chamar no WhatsApp
					<span>💬</span>
				</a>
			</div>
		</section>
	</main>
</Layout>
